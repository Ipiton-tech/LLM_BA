# Конфигурация сборки Diplodoc
allowHTML: true
outputFormat: html

# Подключаем встроенное расширение для работы с GitHub
extensions:
  - github-vcs

# Настройка подключения к GitHub (обязательно для работы authors)
vcs:
  type: github
  # ЗАМЕНИТЕ на URL вашего репозитория
  base: https://github.com/Ipiton-tech/LLM_BA.git

# Включаем отображение авторов и дат изменения
authors:
  enabled: true

# Подключаем кастомные стили
css:
  - ./_assets/styles/custom.css

# Интерфейс
interface:
  search: true
  darkMode: true

# Настройки поиска
search:
  provider: local
  tolerance: 2
  confidense: phrased
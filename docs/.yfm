# Конфигурация сборки Diplodoc
allowHTML: true
outputFormat: html
authors:
  enabled: true

extensions:
    - github-vcs
    - mdit-plugins

# Подключаем кастомные стили
css:
  - ./_assets/styles/custom.css

# Интерфейс
interface:
  search: true
  darkMode: true

# Настройки поиска
search:
  provider: local
  tolerance: 2
  confidense: phrased
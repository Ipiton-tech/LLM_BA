# Конфигурация сборки Diplodoc
allowHTML: true
outputFormat: html

# Авторы (работает через github-vcs автоматически)
authors:
  enabled: true

# Подключаем кастомные стили
css:
  - ./_assets/styles/custom.css

# Интерфейс
interface:
  search: true
  darkMode: true

# Настройки поиска
search:
  provider: local
  tolerance: 2
  confidense: phrased